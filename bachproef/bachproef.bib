@Thesis{Nygren2024,
  author       = {Nygren, Fredrik and Tran, Phong},
  date         = {2024-06-20},
  institution  = {JTH, Department of Computer Science and Informatics},
  title        = {Streaming in the Dark: Analysing video streaming services for Dark Patterns : A user interface study},
  type         = {bathesis},
  url          = {https://urn.kb.se/resolve?urn=urn:nbn:se:hj:diva-65196},
  urldate      = {2025-12-08},
  abstractnote = {Dark patterns are user interface design strategies that benefit an online service by tricking users into making unintentional decisions. Dark patterns have been used to trick users into financial decisions that they did not intend to and disclosing personal information. They have been found in video games, social media platforms, mobile applications and shopping websites et cetera. Previous research in the aforementioned fields has attempted to tackle these problems. However, the video streaming sector remains understudied. To capture dark patterns in the video streaming sector, YouTube, Dailymotion, Disney+, Prime Video, and Netflix were investigated. A comparison between dark pattern applicability in free versus paid-for services and differences in their implementation between mobile and desktop was done. An inspection method was employed to evaluate and capture the dark patterns in the streaming services’ user interfaces. By using previously established literature on dark patterns, an instructional and informative protocol was created, which guided the research. Findings include that in total, these services contain 14 dark patterns. Both paid and free video streaming services contain dark patterns. On paid services, these patterns mainly centre around the subscription aspect of the service. Dark patterns are present on both desktop and mobile platforms, with mobile versions potentially being more invasive. Conclusions are that dark patterns are prevalent in the video streaming sector despite being technically illegal; they affect cookie preferences, subscription processes, and app usage. There are minimal differences in the frequency of dark patterns between paid and free services. We contribute with the identification of dark patterns in an understudied context, how monetization model and device type affect dark pattern manifestation, and a systematic method that proves effective for capturing and describing dark patterns.},
}

@Article{Gunawan2021,
  author       = {Gunawan, Johanna and Pradeep, Amogh and Choffnes, David and Hartzog, Woodrow and Wilson, Christo},
  date         = {2021-10-18},
  journaltitle = {Proceedings of the ACM on Human-Computer Interaction},
  title        = {A Comparative Study of Dark Patterns Across Web and Mobile Modalities},
  doi          = {10.1145/3479521},
  number       = {CSCW2},
  pages        = {1--29},
  url          = {https://doi.org/10.1145/3479521},
  urldate      = {2025-12-08},
  volume       = {5},
  abstract     = {Dark patterns are user interface elements that can influence a person's behavior against their intentions or best interests. Prior work identified these patterns in websites and mobile apps, but little is known about how the design of platforms might impact dark pattern manifestations and related human vulnerabilities. In this paper, we conduct a comparative study of mobile application, mobile browser, and web browser versions of 105 popular services to investigate variations in dark patterns across modalities. We perform manual tests, identify dark patterns in each service, and examine how they persist or differ by modality. Our findings show that while services can employ some dark patterns equally across modalities, many dark patterns vary between platforms, and that these differences saddle people with inconsistent experiences of autonomy, privacy, and control. We conclude by discussing broader implications for policymakers and practitioners, and provide suggestions for furthering dark patterns research.},
  articleno    = {377},
  issue_date   = {October 2021},
  journal      = {Proc. ACM Hum.-Comput. Interact.},
  keywords     = {UX design, consumer protection, dark patterns, deceptive content, manipulation, nudging},
  location     = {New York, NY, USA},
  numpages     = {29},
  publisher    = {Association for Computing Machinery},
}

